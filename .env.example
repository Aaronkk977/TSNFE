# ============================================================================
# Taiwan Analyst Signal Pipeline - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NOTE: Never commit .env to version control
# ============================================================================

# ============================================================================
# YouTube API Configuration
# ============================================================================
# Get your API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_API_KEY_BACKUP=

# ============================================================================
# LLM API Keys
# ============================================================================
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Generative AI: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ============================================================================
# Pipeline Configuration
# ============================================================================
# Choose LLM provider: openai, anthropic, gemini
LLM_PROVIDER=gemini

# Gemini model options: gemini-2.5-flash, gemini-2.5-pro
LLM_MODEL=gemini-2.5-flash

# Whisper configuration (optional fallback)
# Model size: tiny, base, small, medium, large
WHISPER_MODEL=medium

# Device for Whisper fallback: cuda (GPU) or cpu
WHISPER_DEVICE=cuda

# Compute type for Whisper fallback: float32, float16, int8
WHISPER_COMPUTE_TYPE=float16

# ============================================================================
# Processing Configuration
# ============================================================================
# Maximum concurrent downloads
MAX_CONCURRENT_DOWNLOADS=3

# Transcription batch size
TRANSCRIPTION_BATCH_SIZE=5

# Extract only top N signals per video (for filtering)
TOP_SIGNALS_ONLY=10

# LLM extraction temperature (0.0-1.0)
# Lower = more deterministic, higher = more creative
LLM_TEMPERATURE=0.1

# Maximum tokens for LLM response
LLM_MAX_TOKENS=your_llm_max_tokens_here

# ============================================================================
# Storage & Paths
# ============================================================================
# Base data directory
DATA_DIR=./data

# Logging directory
LOG_DIR=./logs

# ============================================================================
# Logging Configuration
# ============================================================================
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log to file: true or false
LOG_TO_FILE=true

# Log to console: true or false
LOG_TO_CONSOLE=true

# ============================================================================
# Retry Configuration
# ============================================================================
# Maximum retry attempts
MAX_RETRIES=3

# Initial wait time in seconds (exponential backoff)
RETRY_BASE_WAIT=1

# Maximum wait time in seconds between retries
RETRY_MAX_WAIT=60

# ============================================================================
# API Rate Limiting
# ============================================================================
# Daily API budget in USD (for cost control)
DAILY_BUDGET_USD=100.0

# Enable cost tracking: true or false
ENABLE_COST_TRACKING=true

# ============================================================================
# Feature Flags
# ============================================================================
# Use caching for intermediate results
ENABLE_CACHING=true

# Cleanup temporary files after successful processing
CLEANUP_TEMP_FILES=true

# Validate stock codes against official list
VALIDATE_STOCK_CODES=true

# ============================================================================
# Proxy Configuration (Optional)
# ============================================================================
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8443
